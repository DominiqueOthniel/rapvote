# Supabase Postgres (pooler Transaction, port 6543)
# Ne mets pas sslmode=require dans l'URL (pg 8 le traite comme verify-full).
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connexion directe (port 5432) pour prisma migrate / db push
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Supabase Storage (photos candidats) · Project Settings → API
# SUPABASE_URL=https://PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ... (service_role, pas anon)

AUTH_SECRET="change-me-long-random-string"

# Notch Pay (encaisser votes + verser gains artistes)
# NOTCHPAY_PUBLIC_KEY=pk.....
# NOTCHPAY_PRIVATE_KEY=sk.....
# NOTCHPAY_BASE_URL=https://api.notchpay.co
# (ne mets JAMAIS https://business.notchpay.co)
# NOTCHPAY_WEBHOOK_HASH=hsk_live_... (Settings → Webhooks → Hash Key)
# Whitelist IP: https://business.notchpay.co/settings/developer/ips
# Webhook URL: https://TON_SITE.netlify.app/api/webhooks/notchpay
# Events: payment.complete, payment.failed, payment.canceled
