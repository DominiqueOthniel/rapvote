generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Season {
  id                 String        @id @default(cuid())
  title              String
  tagline            String?
  isActive           Boolean       @default(true)
  registrationsOpen  Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  phases             Phase[]
  candidates         Candidate[]
  packages           VotePackage[]
}

model Phase {
  id          String       @id @default(cuid())
  seasonId    String
  number      Int
  title       String
  theme       String?
  status      String       @default("upcoming")
  votesOpen   Boolean      @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  season      Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  entries     PhaseEntry[]
  votes       Vote[]
  transactions Transaction[]
  tracks      PhaseTrack[]

  @@unique([seasonId, number])
}

model Candidate {
  id              String       @id @default(cuid())
  seasonId        String
  stageName       String
  slug            String       @unique
  email           String?      @unique
  passwordHash    String?
  city            String?
  bio             String?
  photoUrl        String?
  audioUrl        String?
  phone           String?
  phoneOrange     String?
  phoneMtn        String?
  status          String       @default("active")
  source          String       @default("admin")
  totalVotes      Int          @default(0)
  totalEarnedXaf  Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  season          Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  entries         PhaseEntry[]
  votes           Vote[]
  transactions    Transaction[]
  payouts         Payout[]
  payoutRequests  PayoutRequest[]
  tracks          PhaseTrack[]
  notifications   CandidateNotification[]
}

model CandidateNotification {
  id          String    @id @default(cuid())
  candidateId String
  type        String
  trackId     String?
  fanId       String?
  commentId   String?
  title       String
  body        String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId, createdAt])
  @@index([candidateId, readAt])
}

model PhaseEntry {
  id          String    @id @default(cuid())
  phaseId     String
  candidateId String
  status      String    @default("active")
  votesCount  Int       @default(0)
  juryScore   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  phase       Phase     @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  juryScores  JuryScore[]

  @@unique([phaseId, candidateId])
}

model Jury {
  id           String      @id @default(cuid())
  email        String      @unique
  name         String
  passwordHash String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  scores       JuryScore[]
}

model JuryScore {
  id           String     @id @default(cuid())
  juryId       String
  phaseEntryId String
  score        Int        @default(0)
  breakdown    Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  jury         Jury       @relation(fields: [juryId], references: [id], onDelete: Cascade)
  phaseEntry   PhaseEntry @relation(fields: [phaseEntryId], references: [id], onDelete: Cascade)

  @@unique([juryId, phaseEntryId])
}

model VotePackage {
  id          String   @id @default(cuid())
  seasonId    String
  label       String
  votesCount  Int
  priceXaf    Int
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  season      Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id               String    @id @default(cuid())
  reference        String    @unique
  seasonId         String?
  phaseId          String
  candidateId      String
  packageId        String
  voterPhone       String
  voterName        String?
  operator         String
  votesCount       Int
  amountXaf        Int
  candidateShareXaf Int      @default(0)
  adminShareXaf    Int       @default(0)
  status           String    @default("pending")
  campayRef        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  paidAt           DateTime?
  phase            Phase     @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  candidate        Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  package          VotePackage @relation(fields: [packageId], references: [id])
  votes            Vote[]
}

model Vote {
  id            String   @id @default(cuid())
  phaseId       String
  candidateId   String
  transactionId String
  votesCount    Int
  createdAt     DateTime @default(now())
  phase         Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model Payout {
  id            String    @id @default(cuid())
  candidateId   String
  amountXaf     Int
  phone         String
  channel       String
  reference     String    @unique
  notchId       String?
  status        String    @default("pending")
  description   String?
  failureReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  completedAt   DateTime?
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model PayoutRequest {
  id          String    @id @default(cuid())
  candidateId String
  amountXaf   Int
  phone       String?
  message     String?
  status      String    @default("pending")
  adminNote   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  handledAt   DateTime?
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model Fan {
  id        String         @id @default(cuid())
  name      String
  phone     String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  comments  TrackComment[]
  likes     TrackLike[]
}

model PhaseTrack {
  id            String         @id @default(cuid())
  candidateId   String
  phaseId       String
  title         String?
  audioUrl      String
  lyrics        String?
  playCount     Int            @default(0)
  downloadCount Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  candidate     Candidate      @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  phase         Phase          @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  comments      TrackComment[]
  likes         TrackLike[]

  @@unique([candidateId, phaseId])
}

model TrackComment {
  id            String     @id @default(cuid())
  trackId       String
  fanId         String
  body          String
  likedByArtist Boolean    @default(false)
  createdAt     DateTime   @default(now())
  track         PhaseTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  fan           Fan        @relation(fields: [fanId], references: [id], onDelete: Cascade)
}

model TrackLike {
  id        String     @id @default(cuid())
  trackId   String
  fanId     String
  createdAt DateTime   @default(now())
  track     PhaseTrack @relation(fields: [trackId], references: [id], onDelete: Cascade)
  fan       Fan        @relation(fields: [fanId], references: [id], onDelete: Cascade)

  @@unique([trackId, fanId])
}
